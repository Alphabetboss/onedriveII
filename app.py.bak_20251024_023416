_CANON_DEFAULT = {
    "enabled": True,
    "zone": 1,
    "start_time": "05:00",
    "duration_min": 10,
    "frequency": "daily",
    "every_x_days": None,
}

def _normalize_time(hhmm: str) -> Optional[str]:
    """Accepts 5:30, 05:30, 5am, 5:30am, 17:00, etc. Returns 'HH:MM' or None."""
    if not isinstance(hhmm, str):
        return None
    t = hhmm.strip().lower().replace(" ", "")
    m = re.match(r"^(\d{1,2})(?::?(\d{2}))?(am|pm)?$", t)
    if not m:
        return None
    hh = int(m.group(1))
    mm = int(m.group(2) or 0)
    ap = m.group(3)
    if ap:
        if ap == "pm" and hh < 12:
            hh += 12
        if ap == "am" and hh == 12:
            hh = 0
    if 0 <= hh <= 23 and 0 <= mm <= 59:
        return f"{hh:02d}:{mm:02d}"
    return None

def _normalize_loaded_schedule(obj: dict) -> dict:
    """Normalize legacy + canonical schedule keys."""
    if not isinstance(obj, dict):
        obj = {}
    start_time = obj.get("start_time", obj.get("start_time_local", _CANON_DEFAULT["start_time"]))
    duration_min = obj.get("duration_min", obj.get("duration_minutes", _CANON_DEFAULT["duration_min"]))
    frequency = str(obj.get("frequency", "daily")).lower().strip()
    every_x_days = obj.get("every_x_days", None)

    try:
        zone = int(obj.get("zone", 1))
    except Exception:
        zone = 1

    try:
        duration_min = int(duration_min)
    except Exception:
        duration_min = _CANON_DEFAULT["duration_min"]
    if duration_min <= 0:
        duration_min = _CANON_DEFAULT["duration_min"]

    if frequency not in ("daily", "every_x_days"):
        frequency = "daily"

    if frequency == "every_x_days":
        try:
            every_x_days = int(every_x_days) if every_x_days is not None else None
        except Exception:
            every_x_days = None
        if not every_x_days or every_x_days < 1:
            every_x_days = 2

    start_time = _normalize_time(start_time) or _CANON_DEFAULT["start_time"]

    return {
        "enabled": bool(obj.get("enabled", True)),
        "zone": zone,
        "start_time": start_time,
        "duration_min": duration_min,
        "frequency": frequency,
        "every_x_days": every_x_days,
    }

def save_schedule(obj: dict) -> None:
    canon = _normalize_loaded_schedule(obj)
    SCHEDULE_JSON.write_text(json.dumps(canon, indent=2), "utf-8")

def load_schedule() -> dict:
    if SCHEDULE_JSON.exists():
        try:
            data = json.loads(SCHEDULE_JSON.read_text("utf-8"))
        except Exception:
            data = {}
    else:
        data = {}
    canon = _normalize_loaded_schedule(data)
    save_schedule(canon)
    return canon

