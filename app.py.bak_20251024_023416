# Weather (Open-Meteo, no API key)
# =========================================================
def get_quick_weather(lat: float = DEFAULT_LAT, lon: float = DEFAULT_LON) -> dict:
    try:
        url = (
            "https://api.open-meteo.com/v1/forecast"
            f"?latitude={lat}&longitude={lon}"
            "&hourly=temperature_2m,precipitation"
            "&current=temperature_2m,precipitation"
            "&timezone=auto"
        )
        r = requests.get(url, timeout=6)
        r.raise_for_status()
        j = r.json()
        cur = j.get("current", {})
        return {"temp_c": cur.get("temperature_2m"), "precip_mm": cur.get("precipitation")}
    except Exception:
        return {"temp_c": None, "precip_mm": None}

# =========================================================
# Local fallback brain
# =========================================================
def _fallback_brain(txt: str, schedule: dict, weather: dict) -> str:
    t = txt.lower()
    zone = int(schedule.get("zone", 1))
    start = str(schedule.get("start_time", "05:00"))
    dur = int(schedule.get("duration_min", 10))
    freq = schedule.get("frequency", "daily")
    if not isinstance(freq, str):
        freq = "daily"
    freq_disp = freq.replace("_", " ")

    if "schedule" in t or "start time" in t or "duration" in t:
        return f"Your schedule is zone {zone} at {start} for {dur} min, {freq_disp}."
    if any(k in t for k in ["hello", "hi", "hey", "yo"]):
        return "Hey there! I can adjust duration, start time, or skip if it rains."
    if "weather" in t:
        return f"Quick read: temp≈{weather.get('temp_c')}°C, precip≈{weather.get('precip_mm')} mm."
    return "Got it! I can adjust schedules, run manual cycles, or skip for rain."

# =========================================================
# AI reply (hybrid + persistent memory)
# =========================================================
def ai_reply(user_text: str) -> str:
    txt = (user_text or "").strip()
    if not txt:
        return "Hey! I'm Astra, your AI Sprinkler Tech. Ask me about watering, weather, or your lawn."

    schedule = load_schedule()
    weather = get_quick_weather()
    CHAT_MEMORY.extend(load_chat_memory())
    CHAT_MEMORY.append({"role": "user", "content": txt})

    if not OPENAI_API_KEY:
        reply = _fallback_brain(txt, schedule, weather)
    else:
        try:
            from openai import OpenAI
            client = OpenAI(api_key=OPENAI_API_KEY)
            messages = [{"role": m["role"], "content": m["content"]} for m in CHAT_MEMORY]
            messages_param = cast(Any, messages)
            resp = client.chat.completions.create(
                model=MODEL_NAME,
                messages=messages_param,
                temperature=0.8,
                max_tokens=300,
            )
            content = None
            try:
                choice = resp.choices[0] if getattr(resp, "choices", None) else None
                msg = getattr(choice, "message", None) if choice is not None else None
                if isinstance(msg, dict):
                    content = msg.get("content")
                else:
                    content = getattr(msg, "content", None)
            except Exception:
                content = None
            reply = content.strip() if content else _fallback_brain(txt, schedule, weather)
        except Exception as e:
            reply = f"(Fallback mode) Could not reach AI service: {e}\n" + _fallback_brain(txt, schedule, weather)

    CHAT_MEMORY.append({"role": "assistant", "content": reply})
    save_chat_memory(list(CHAT_MEMORY))
    return reply

