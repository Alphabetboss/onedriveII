def _key_is_plausible(key: str) -> bool:
    """Quick sanity check for valid key pattern."""
    return bool(key) and key.startswith("sk-") and len(key) > 20


def call_ai(messages):
    """
    Minimal OpenAI Chat Completions call with strong error handling.
    Returns (ok: bool, text: str)
    """
    if not _key_is_plausible(OPENAI_API_KEY):
        return False, (
            "AI is in fallback mode: missing or invalid API key.\n"
            "Fix: add OPENAI_API_KEY to your .env or setx it in PowerShell."
        )

    payload = {
        "model": MODEL_NAME,
        "messages": messages,
        "temperature": 0.4,
        "max_tokens": 300,
    }
    headers = {
        "Authorization": f"Bearer {OPENAI_API_KEY}",
        "Content-Type": "application/json",
    }

    try:
        r = requests.post(OPENAI_URL, headers=headers, json=payload, timeout=30)
    except requests.RequestException as e:
        return False, f"AI network error. Fallback reply. Details: {e}"

    # Clean error handling
    if r.status_code != 200:
        try:
            err = r.json()
        except Exception:
            err = {"error": {"message": r.text[:200]}}

        status = r.status_code
        code = (err.get("error") or {}).get("code", "")
        msg = (err.get("error") or {}).get("message", "Unknown error")

        if status == 401:
            short = "Invalid or missing OpenAI API key. Update OPENAI_API_KEY."
        elif status == 429:
            short = "Rate limited or quota exceeded. Try again or check billing."
        else:
            short = f"AI call failed ({status})."

        return False, f"{short} (code: {code or 'n/a'}; msg: {msg[:160]})"

    # Parse successful response
    try:
        data = r.json()
        text = data["choices"][0]["message"]["content"].strip()
        return True, text
    except Exception as e:
        return False, f"AI response parse error. Fallback reply. Details: {e}"


