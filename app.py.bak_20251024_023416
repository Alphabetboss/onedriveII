@app.route("/chat", methods=["POST"])
def chat():
    """Handle chat interactions."""
    user_msg = (request.json or {}).get("message", "").strip()[:1000]
    if not user_msg:
        return jsonify({"ok": False, "reply": "Please type a message."})

    CHAT_MEMORY.append({"role": "user", "content": user_msg})
    messages = [{"role": "system", "content": "You are Astra, a helpful AI sprinkler technician."}]
    messages.extend(list(CHAT_MEMORY))

    ok, reply = call_ai(messages)
    CHAT_MEMORY.append({"role": "assistant", "content": reply})

    return jsonify({"ok": ok, "reply": reply})


